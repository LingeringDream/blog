# 博客 API 密钥 (必须设置，用于管理后台认证)
BLOG_API_KEY=your-secret-api-key-here

# 服务端口 (可选，默认 3000)
# PORT=3000

# 数据库路径 (可选，默认 ./blog.db)
# 容器部署建议设置为持久化存储路径
# DB_PATH=/app/data/blog.db

# ==================== AI 图片生成配置 ====================
# API 地址 (兼容 OpenAI / DALL·E / 通义万相 / 其他兼容接口)
# AI_IMAGE_API_URL=https://api.openai.com/v1/images/generations

# API 密钥
# AI_IMAGE_API_KEY=sk-xxxx

# 模型名称 (可选，默认 dall-e-3)
# AI_IMAGE_MODEL=dall-e-3

# 图片尺寸 (可选，默认 1024x1024)
# AI_IMAGE_SIZE=1024x1024

# ==================== 文件上传配置 ====================
# 上传文件存储目录 (可选，默认 ./public/uploads)
# UPLOAD_DIR=./public/uploads

# 单文件大小限制，单位 MB (可选，默认 5)
# UPLOAD_MAX_SIZE=5
