# ==================== 必填 ====================
# 管理后台密钥（务必修改为强随机字符串）
BLOG_API_KEY=change-this-to-a-strong-random-string

# 你的域名（用于 SSL 证书申请）
DOMAIN=blog.example.com

# 证书申请邮箱
CERT_EMAIL=your-email@example.com

# ==================== 可选 ====================
# 服务端口（默认 3000）
# PORT=3000

# 数据库路径（容器内路径，通常不需要修改）
# DB_PATH=/app/data/blog.db
